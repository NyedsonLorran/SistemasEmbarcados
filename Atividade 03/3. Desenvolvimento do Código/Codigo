#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/ledc.h"

//  GPIOs 
#define LED1 4
#define LED2 5
#define LED3 6
#define LED4 7
#define BUZZER 2

//  PWM 
#define LEDC_MODE LEDC_LOW_SPEED_MODE
#define LEDC_TIMER LEDC_TIMER_0
#define LEDC_FREQ_LED 1000
#define LEDC_RES LEDC_TIMER_10_BIT

#define DUTY_MAX 1023
#define DELAY_MS 20

//  CONFIG 
void config_pwm() {

    // Configura timer
    ledc_timer_config_t timer_conf = {
        .speed_mode = LEDC_MODE,
        .duty_resolution = LEDC_RES,
        .timer_num = LEDC_TIMER,
        .freq_hz = LEDC_FREQ_LED,
        .clk_cfg = LEDC_AUTO_CLK
    };
    ledc_timer_config(&timer_conf);

    // Canais
    ledc_channel_t channels[] = {
        LEDC_CHANNEL_0,
        LEDC_CHANNEL_1,
        LEDC_CHANNEL_2,
        LEDC_CHANNEL_3,
        LEDC_CHANNEL_4
    };
    int gpios[] = {LED1, LED2, LED3, LED4, BUZZER};

    for (int i = 0; i < 5; i++) {
        ledc_channel_config_t ch_conf = {
            .gpio_num = gpios[i],
            .speed_mode = LEDC_MODE,
            .channel = channels[i],
            .intr_type = LEDC_INTR_DISABLE,
            .timer_sel = LEDC_TIMER,
            .duty = 0,
            .hpoint = 0
        };
        ledc_channel_config(&ch_conf);
    }
}

//  LED 
void set_led(ledc_channel_t channel, float percent) {
    int duty = (percent / 100.0) * DUTY_MAX;
    ledc_set_duty(LEDC_MODE, channel, duty);
    ledc_update_duty(LEDC_MODE, channel);
}

//  BUZZER 
void set_buzzer_freq(int freq) {
    ledc_set_freq(LEDC_MODE, LEDC_TIMER, freq);
    ledc_set_duty(LEDC_MODE, LEDC_CHANNEL_4, DUTY_MAX / 2);
    ledc_update_duty(LEDC_MODE, LEDC_CHANNEL_4);
}

//  FASE 1 
void fase1() {
    printf("=== FASE 1: Fading sincronizado ===\n");

    for (int i = 0; i <= 100; i++) {
        set_led(LEDC_CHANNEL_0, i);
        set_led(LEDC_CHANNEL_1, i);
        set_led(LEDC_CHANNEL_2, i);
        set_led(LEDC_CHANNEL_3, i);
        vTaskDelay(pdMS_TO_TICKS(DELAY_MS));
    }
    for (int i = 100; i >= 0; i--) {
        set_led(LEDC_CHANNEL_0, i);
        set_led(LEDC_CHANNEL_1, i);
        set_led(LEDC_CHANNEL_2, i);
        set_led(LEDC_CHANNEL_3, i);
        vTaskDelay(pdMS_TO_TICKS(DELAY_MS));
    }
}

//  FASE 2 
void fade_led(ledc_channel_t ch) {
    printf("LED canal %d\n", ch);
    for (int i = 0; i <= 100; i++) { set_led(ch, i); vTaskDelay(pdMS_TO_TICKS(DELAY_MS)); }
    for (int i = 100; i >= 0; i--) { set_led(ch, i); vTaskDelay(pdMS_TO_TICKS(DELAY_MS)); }
}

void fase2() {
    printf("=== FASE 2: Fading sequencial ===\n");
    fade_led(LEDC_CHANNEL_0);
    fade_led(LEDC_CHANNEL_1);
    fade_led(LEDC_CHANNEL_2);
    fade_led(LEDC_CHANNEL_3);
}

//  FASE 3 
void fase3() {
    printf("=== FASE 3: Teste do Buzzer ===\n");

    for (int f = 500; f <= 2000; f += 50) {
        printf("Freq: %d Hz\n", f);
        set_buzzer_freq(f);
        vTaskDelay(pdMS_TO_TICKS(100));
    }
    for (int f = 2000; f >= 500; f -= 50) {
        printf("Freq: %d Hz\n", f);
        set_buzzer_freq(f);
        vTaskDelay(pdMS_TO_TICKS(100));
    }

    ledc_set_duty(LEDC_MODE, LEDC_CHANNEL_4, 0);
    ledc_update_duty(LEDC_MODE, LEDC_CHANNEL_4);
}

//  MAIN 
void app_main(void) {
    printf("Sistema iniciado (ESP-IDF)\n");
    config_pwm();

    while (1) {
        fase1();
        fase2();
        fase3();
    }
}