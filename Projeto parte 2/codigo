#include <stdio.h>
#include <string.h>
#include <math.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/queue.h"
#include "driver/ledc.h"
#include "driver/gpio.h"
#include "driver/i2c.h"
#include "esp_adc/adc_oneshot.h"
#include "esp_log.h"
#include "esp_err.h"

#define PIN_JOY_X       ADC_CHANNEL_2
#define PIN_JOY_Y       ADC_CHANNEL_3
#define PIN_JOY_SW      GPIO_NUM_4
#define PIN_SERVO_X     GPIO_NUM_5
#define PIN_SERVO_Y     GPIO_NUM_6
#define PIN_LED_STATUS  GPIO_NUM_8

#define I2C_MASTER_PORT     I2C_NUM_0
#define I2C_SDA_PIN         GPIO_NUM_18
#define I2C_SCL_PIN         GPIO_NUM_17
#define I2C_FREQ_HZ         400000
#define I2C_TIMEOUT_MS      100

#define MPU6050_ADDR            0x68
#define MPU6050_REG_PWR_MGMT_1  0x6B
#define MPU6050_REG_SMPLRT_DIV  0x19
#define MPU6050_REG_CONFIG      0x1A
#define MPU6050_REG_GYRO_CFG    0x1B
#define MPU6050_REG_ACCEL_CFG   0x1C
#define MPU6050_REG_ACCEL_XOUT  0x3B
#define MPU6050_REG_WHO_AM_I    0x75

#define ACCEL_SCALE_2G      16384.0f
#define GYRO_SCALE_250      131.0f
#define COMP_ALPHA          0.96f
#define MPU_SAMPLE_MS       200

#define LEDC_TIMER          LEDC_TIMER_0
#define LEDC_MODE           LEDC_LOW_SPEED_MODE
#define LEDC_FREQ_HZ        50
#define LEDC_RESOLUTION     LEDC_TIMER_14_BIT
#define LEDC_CH_SERVO_X     LEDC_CHANNEL_0
#define LEDC_CH_SERVO_Y     LEDC_CHANNEL_1

#define SERVO_DUTY_MIN      410
#define SERVO_DUTY_CENTER   1229
#define SERVO_DUTY_MAX      2048
#define MAX_TILT_DUTY       800


#define ADC_CENTER  2048
#define DEADZONE    80

typedef struct {
    int  raw_x;
    int  raw_y;
    bool sw;
} joystick_data_t;

typedef struct {
    uint32_t duty_x;
    uint32_t duty_y;
} servo_cmd_t;

typedef struct {
    float accel_x, accel_y, accel_z;
    float gyro_x,  gyro_y,  gyro_z;
    float pitch, roll;
} mpu6050_data_t;

static QueueHandle_t xQueueJoystick;
static QueueHandle_t xQueueServo;
static QueueHandle_t xQueueMPU;

static adc_oneshot_unit_handle_t adc1_handle;

static const char *TAG_JOY  = "JOYSTICK";
static const char *TAG_SERVO = "SERVO";
static const char *TAG_MON  = "MONITOR";
static const char *TAG_MPU  = "MPU6050";
static const char *TAG_MAIN = "MAIN";


static long map_value(long x, long in_min, long in_max, long out_min, long out_max)
{
    if (in_max == in_min) return out_min;
    return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

static uint32_t joystick_to_duty(int adc_val)
{
    int deviation = adc_val - ADC_CENTER;
    if (deviation > -DEADZONE && deviation < DEADZONE)
        return SERVO_DUTY_CENTER;

    uint32_t duty;
    if (deviation >= DEADZONE)
        duty = (uint32_t)map_value(deviation, DEADZONE, ADC_CENTER,
                                   SERVO_DUTY_CENTER, SERVO_DUTY_CENTER + MAX_TILT_DUTY);
    else
        duty = (uint32_t)map_value(deviation, -ADC_CENTER, -DEADZONE,
                                   SERVO_DUTY_CENTER - MAX_TILT_DUTY, SERVO_DUTY_CENTER);

    if (duty < SERVO_DUTY_MIN) duty = SERVO_DUTY_MIN;
    if (duty > SERVO_DUTY_MAX) duty = SERVO_DUTY_MAX;
    return duty;
}


static esp_err_t mpu6050_write_reg(uint8_t reg, uint8_t data)
{
    uint8_t buf[2] = {reg, data};
    return i2c_master_write_to_device(I2C_MASTER_PORT, MPU6050_ADDR,
                                      buf, sizeof(buf),
                                      pdMS_TO_TICKS(I2C_TIMEOUT_MS));
}

static esp_err_t mpu6050_read_reg(uint8_t reg, uint8_t *data, size_t len)
{
    return i2c_master_write_read_device(I2C_MASTER_PORT, MPU6050_ADDR,
                                        &reg, 1, data, len,
                                        pdMS_TO_TICKS(I2C_TIMEOUT_MS));
}

static esp_err_t mpu6050_init(void)
{
    uint8_t who_am_i = 0;
    esp_err_t ret = mpu6050_read_reg(MPU6050_REG_WHO_AM_I, &who_am_i, 1);
    if (ret != ESP_OK) {
        ESP_LOGE(TAG_MPU, "MPU6050 não encontrado (err=0x%x)", ret);
        return ret;
    }
    ESP_LOGI(TAG_MPU, "WHO_AM_I=0x%02X", who_am_i);

    ESP_ERROR_CHECK(mpu6050_write_reg(MPU6050_REG_PWR_MGMT_1, 0x01)); // wake up, clock PLL
    ESP_ERROR_CHECK(mpu6050_write_reg(MPU6050_REG_SMPLRT_DIV, 0x09)); // 100Hz
    ESP_ERROR_CHECK(mpu6050_write_reg(MPU6050_REG_CONFIG,     0x03)); // DLPF 44Hz
    ESP_ERROR_CHECK(mpu6050_write_reg(MPU6050_REG_ACCEL_CFG,  0x00)); // ±2g
    ESP_ERROR_CHECK(mpu6050_write_reg(MPU6050_REG_GYRO_CFG,   0x00)); // ±250°/s

    ESP_LOGI(TAG_MPU, "MPU6050 inicializado.");
    return ESP_OK;
}

static esp_err_t mpu6050_read_raw(mpu6050_data_t *out)
{
    uint8_t buf[14];
    esp_err_t ret = mpu6050_read_reg(MPU6050_REG_ACCEL_XOUT, buf, 14);
    if (ret != ESP_OK) return ret;

    int16_t raw_ax = (int16_t)((buf[0]  << 8) | buf[1]);
    int16_t raw_ay = (int16_t)((buf[2]  << 8) | buf[3]);
    int16_t raw_az = (int16_t)((buf[4]  << 8) | buf[5]);
    int16_t raw_gx = (int16_t)((buf[8]  << 8) | buf[9]);
    int16_t raw_gy = (int16_t)((buf[10] << 8) | buf[11]);
    int16_t raw_gz = (int16_t)((buf[12] << 8) | buf[13]);

    out->accel_x = (float)raw_ax / ACCEL_SCALE_2G;
    out->accel_y = (float)raw_ay / ACCEL_SCALE_2G;
    out->accel_z = (float)raw_az / ACCEL_SCALE_2G;
    out->gyro_x  = (float)raw_gx / GYRO_SCALE_250;
    out->gyro_y  = (float)raw_gy / GYRO_SCALE_250;
    out->gyro_z  = (float)raw_gz / GYRO_SCALE_250;
    return ESP_OK;
}


static void i2c_init(void)
{
    i2c_config_t conf = {
        .mode             = I2C_MODE_MASTER,
        .sda_io_num       = I2C_SDA_PIN,
        .scl_io_num       = I2C_SCL_PIN,
        .sda_pullup_en    = GPIO_PULLUP_ENABLE,
        .scl_pullup_en    = GPIO_PULLUP_ENABLE,
        .master.clk_speed = I2C_FREQ_HZ,
    };
    ESP_ERROR_CHECK(i2c_param_config(I2C_MASTER_PORT, &conf));
    ESP_ERROR_CHECK(i2c_driver_install(I2C_MASTER_PORT, I2C_MODE_MASTER, 0, 0, 0));
}

static void ledc_init(void)
{
    ledc_timer_config_t timer_cfg = {
        .speed_mode      = LEDC_MODE,
        .duty_resolution = LEDC_RESOLUTION,
        .timer_num       = LEDC_TIMER,
        .freq_hz         = LEDC_FREQ_HZ,
        .clk_cfg         = LEDC_AUTO_CLK,
    };
    ESP_ERROR_CHECK(ledc_timer_config(&timer_cfg));

    ledc_channel_config_t ch_x = {
        .speed_mode = LEDC_MODE, .channel = LEDC_CH_SERVO_X,
        .timer_sel  = LEDC_TIMER, .intr_type = LEDC_INTR_DISABLE,
        .gpio_num   = PIN_SERVO_X, .duty = SERVO_DUTY_CENTER, .hpoint = 0,
    };
    ledc_channel_config_t ch_y = {
        .speed_mode = LEDC_MODE, .channel = LEDC_CH_SERVO_Y,
        .timer_sel  = LEDC_TIMER, .intr_type = LEDC_INTR_DISABLE,
        .gpio_num   = PIN_SERVO_Y, .duty = SERVO_DUTY_CENTER, .hpoint = 0,
    };
    ESP_ERROR_CHECK(ledc_channel_config(&ch_x));
    ESP_ERROR_CHECK(ledc_channel_config(&ch_y));
}

static void adc_init(void)
{
    adc_oneshot_unit_init_cfg_t init_cfg = {
        .unit_id = ADC_UNIT_1, .ulp_mode = ADC_ULP_MODE_DISABLE,
    };
    ESP_ERROR_CHECK(adc_oneshot_new_unit(&init_cfg, &adc1_handle));

    adc_oneshot_chan_cfg_t chan_cfg = {
        .bitwidth = ADC_BITWIDTH_12, .atten = ADC_ATTEN_DB_12,
    };
    ESP_ERROR_CHECK(adc_oneshot_config_channel(adc1_handle, PIN_JOY_X, &chan_cfg));
    ESP_ERROR_CHECK(adc_oneshot_config_channel(adc1_handle, PIN_JOY_Y, &chan_cfg));
}


static void task_joystick(void *pvParam)
{
    ESP_LOGI(TAG_JOY, "Iniciada.");
    joystick_data_t joy = {0};
    while (1) {
        ESP_ERROR_CHECK(adc_oneshot_read(adc1_handle, PIN_JOY_X, &joy.raw_x));
        ESP_ERROR_CHECK(adc_oneshot_read(adc1_handle, PIN_JOY_Y, &joy.raw_y));
        joy.sw = (gpio_get_level(PIN_JOY_SW) == 0);
        xQueueOverwrite(xQueueJoystick, &joy);
        vTaskDelay(pdMS_TO_TICKS(20));
    }
}


static void task_servos(void *pvParam)
{
    ESP_LOGI(TAG_SERVO, "Iniciada.");
    joystick_data_t joy = {0};
    servo_cmd_t cmd = {SERVO_DUTY_CENTER, SERVO_DUTY_CENTER};
    const float ALPHA = 0.55f;
    float smooth_x = SERVO_DUTY_CENTER;
    float smooth_y = SERVO_DUTY_CENTER;

    while (1) {
        if (xQueueReceive(xQueueJoystick, &joy, pdMS_TO_TICKS(30)) == pdTRUE) {
            smooth_x = ALPHA * joystick_to_duty(joy.raw_x) + (1.0f - ALPHA) * smooth_x;
            smooth_y = ALPHA * joystick_to_duty(joy.raw_y) + (1.0f - ALPHA) * smooth_y;

            cmd.duty_x = (uint32_t)smooth_x;
            cmd.duty_y = (uint32_t)smooth_y;

            ledc_set_duty(LEDC_MODE, LEDC_CH_SERVO_X, cmd.duty_x);
            ledc_update_duty(LEDC_MODE, LEDC_CH_SERVO_X);
            ledc_set_duty(LEDC_MODE, LEDC_CH_SERVO_Y, cmd.duty_y);
            ledc_update_duty(LEDC_MODE, LEDC_CH_SERVO_Y);

            xQueueOverwrite(xQueueServo, &cmd);
        }
    }
}


static void task_monitor(void *pvParam)
{
    ESP_LOGI(TAG_MON, "Iniciada.");
    joystick_data_t joy = {0};
    servo_cmd_t     cmd = {0};
    mpu6050_data_t  mpu = {0};
    uint32_t cnt = 0;

    while (1) {
        cnt++;
        xQueuePeek(xQueueJoystick, &joy, 0);
        xQueuePeek(xQueueServo,    &cmd, 0);
        xQueuePeek(xQueueMPU,      &mpu, 0);

        ESP_LOGI(TAG_MON,
                 "[#%lu] JOY X=%4d Y=%4d SW=%d | SERVO X=%4lu Y=%4lu | "
                 "PITCH=%.1f° ROLL=%.1f° | Heap=%lu",
                 (unsigned long)cnt,
                 joy.raw_x, joy.raw_y, joy.sw ? 1 : 0,
                 (unsigned long)cmd.duty_x, (unsigned long)cmd.duty_y,
                 mpu.pitch, mpu.roll,
                 (unsigned long)esp_get_free_heap_size());

        if (joy.sw)
            ESP_LOGW(TAG_MON, "Botão pressionado!");

        vTaskDelay(pdMS_TO_TICKS(500));
    }
}


static void task_mpu6050(void *pvParam)
{
    ESP_LOGI(TAG_MPU, "Iniciada.");
    mpu6050_data_t mpu = {0};
    float pitch = 0.0f, roll = 0.0f;
    const float dt = MPU_SAMPLE_MS / 1000.0f;

    while (1) {
        if (mpu6050_read_raw(&mpu) == ESP_OK) {
            float accel_pitch = atan2f(mpu.accel_x,
                                sqrtf(mpu.accel_y * mpu.accel_y +
                                      mpu.accel_z * mpu.accel_z)) * (180.0f / M_PI);
            float accel_roll  = atan2f(mpu.accel_y,
                                sqrtf(mpu.accel_x * mpu.accel_x +
                                      mpu.accel_z * mpu.accel_z)) * (180.0f / M_PI);

            pitch = COMP_ALPHA * (pitch + mpu.gyro_y * dt) + (1.0f - COMP_ALPHA) * accel_pitch;
            roll  = COMP_ALPHA * (roll  + mpu.gyro_x * dt) + (1.0f - COMP_ALPHA) * accel_roll;

            mpu.pitch = pitch;
            mpu.roll  = roll;

            xQueueOverwrite(xQueueMPU, &mpu);

            printf("{\"pitch\":%.2f,\"roll\":%.2f,"
                   "\"ax\":%.3f,\"ay\":%.3f,\"az\":%.3f,"
                   "\"gx\":%.2f,\"gy\":%.2f,\"gz\":%.2f}\n",
                   mpu.pitch, mpu.roll,
                   mpu.accel_x, mpu.accel_y, mpu.accel_z,
                   mpu.gyro_x,  mpu.gyro_y,  mpu.gyro_z);
        } else {
            ESP_LOGW(TAG_MPU, "Falha na leitura I2C");
        }

        vTaskDelay(pdMS_TO_TICKS(MPU_SAMPLE_MS));
    }
}


void app_main(void)
{
    ESP_LOGI(TAG_MAIN, "Mesa Labirinto - Fase 2 - ESP32-C6");

    gpio_reset_pin(PIN_LED_STATUS);
    gpio_set_direction(PIN_LED_STATUS, GPIO_MODE_OUTPUT);
    gpio_set_level(PIN_LED_STATUS, 0);

    gpio_reset_pin(PIN_JOY_SW);
    gpio_set_direction(PIN_JOY_SW, GPIO_MODE_INPUT);
    gpio_set_pull_mode(PIN_JOY_SW, GPIO_PULLUP_ONLY);

    adc_init();
    ledc_init();
    i2c_init();

    if (mpu6050_init() != ESP_OK) {
        ESP_LOGE(TAG_MAIN, "Falha MPU6050. Verifique a fiação I2C!");
        while (1) vTaskDelay(pdMS_TO_TICKS(1000));
    }

    xQueueJoystick = xQueueCreate(1, sizeof(joystick_data_t));
    xQueueServo    = xQueueCreate(1, sizeof(servo_cmd_t));
    xQueueMPU      = xQueueCreate(1, sizeof(mpu6050_data_t));

    if (!xQueueJoystick || !xQueueServo || !xQueueMPU) {
        ESP_LOGE(TAG_MAIN, "Falha ao criar filas!");
        while (1) vTaskDelay(pdMS_TO_TICKS(1000));
    }

    xTaskCreate(task_joystick, "task_joystick", 2048, NULL, 3, NULL);
    xTaskCreate(task_servos,   "task_servos",   2048, NULL, 2, NULL);
    xTaskCreate(task_monitor,  "task_monitor",  3072, NULL, 1, NULL);
    xTaskCreate(task_mpu6050,  "task_mpu6050",  4096, NULL, 3, NULL);

    vTaskDelay(pdMS_TO_TICKS(500));
    gpio_set_level(PIN_LED_STATUS, 1);
    ESP_LOGI(TAG_MAIN, "Sistema pronto.");
}