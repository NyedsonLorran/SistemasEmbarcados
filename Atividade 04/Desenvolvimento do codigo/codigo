#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/gpio.h"
#include "esp_timer.h"

// LEDs
#define LED1_GPIO 4
#define LED2_GPIO 5
#define LED3_GPIO 6
#define LED4_GPIO 7

// Botões 
#define BUTTON_A_GPIO 3   // Contagem
#define BUTTON_B_GPIO 18  // Incremento

#define DEBOUNCE_US 200000  // 200 ms

static uint8_t contador = 0;
static uint8_t incremento = 1;

static int64_t last_press_A = 0;
static int64_t last_press_B = 0;

//  LED 
void config_leds(void) {
    gpio_config_t io_conf = {
        .pin_bit_mask = (1ULL << LED1_GPIO) |
                        (1ULL << LED2_GPIO) |
                        (1ULL << LED3_GPIO) |
                        (1ULL << LED4_GPIO),
        .mode = GPIO_MODE_OUTPUT,
        .pull_up_en = 0,
        .pull_down_en = 0,
        .intr_type = GPIO_INTR_DISABLE
    };

    gpio_config(&io_conf);

    // começa apagados
    gpio_set_level(LED1_GPIO, 0);
    gpio_set_level(LED2_GPIO, 0);
    gpio_set_level(LED3_GPIO, 0);
    gpio_set_level(LED4_GPIO, 0);
}

//  BOTÕES 
void config_botoes(void) {
    gpio_config_t io_conf = {
        .pin_bit_mask = (1ULL << BUTTON_A_GPIO) |
                        (1ULL << BUTTON_B_GPIO),
        .mode = GPIO_MODE_INPUT,
        .pull_up_en = 1,   //ativa pull-up
        .pull_down_en = 0,
        .intr_type = GPIO_INTR_DISABLE
    };

    gpio_config(&io_conf);
}

//  LEDs BINÁRIOS 
void atualiza_leds(uint8_t valor) {
    gpio_set_level(LED1_GPIO, (valor >> 3) & 1);
    gpio_set_level(LED2_GPIO, (valor >> 2) & 1);
    gpio_set_level(LED3_GPIO, (valor >> 1) & 1);
    gpio_set_level(LED4_GPIO, (valor >> 0) & 1);
}

//  LEITURA DOS BOTÕES 
void checa_botoes(void) {
    int estado_A = gpio_get_level(BUTTON_A_GPIO);
    int estado_B = gpio_get_level(BUTTON_B_GPIO);

    int64_t agora = esp_timer_get_time();

    // Botão A → incrementa contador
    if (estado_A == 0 && (agora - last_press_A) > DEBOUNCE_US) {
        last_press_A = agora;
        contador = (contador + incremento) & 0x0F;
        atualiza_leds(contador);
    }

    // Botão B → alterna incremento
    if (estado_B == 0 && (agora - last_press_B) > DEBOUNCE_US) {
        last_press_B = agora;
        incremento = (incremento == 1) ? 2 : 1;
    }
}

//  MAIN 
void app_main(void) {
    config_leds();
    config_botoes();

    while (1) {
        checa_botoes();
        vTaskDelay(pdMS_TO_TICKS(50));
    }
}